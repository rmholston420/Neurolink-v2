# Neurolink-v2 environment configuration
# Copy this file to .env and edit as needed.

# --- Device ---
# Leave blank for auto-discovery via BLE scan
MUSE_MAC_ADDRESS=
MUSE_SERIAL_NUMBER=

# BrainFlow startup options for Muse S Athena
# p1041 = 8-ch EEG + 16-ch optics (default) | p1035 = 4-ch EEG + 4-ch optics (low-power)
MUSE_PRESET=p1041
MUSE_LOW_LATENCY=true

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./neurolink.db
